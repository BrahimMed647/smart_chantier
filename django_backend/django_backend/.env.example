# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.

# -------------------------------------------------------
# SECURITY — generate a new key at:
# https://djecrety.ir/
# -------------------------------------------------------
SECRET_KEY=your-very-long-random-secret-key-here

# Set to False in production
DEBUG=False

# Your Railway domain (no https://)
# Example: smartchantier-production.up.railway.app
ALLOWED_HOSTS=smartchantier-production.up.railway.app,localhost,127.0.0.1

# Same domain but with https://
CSRF_TRUSTED_ORIGINS=https://smartchantier-production.up.railway.app,http://localhost:8000

# -------------------------------------------------------
# DATABASE — Railway provides this automatically
# when you add a PostgreSQL service to your project.
# It looks like: postgresql://user:pass@host:port/dbname
# -------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -------------------------------------------------------
# CORS — which origins can call the API
# -------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://smartchantier-production.up.railway.app
